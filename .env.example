# MTProto (my.telegram.org → API development tools)
TG_API_ID=
TG_API_HASH=

# Бот-модератор/публикатор (@BotFather)
BOT_TOKEN=

# (необязательно) Куда бот шлёт черновики; по умолчанию — личка аккаунта из `bun run login`
ADMIN_CHAT_ID=

# Канал для публикации: @username или -100xxxxxxxxxx (бот должен быть админом)
CHANNEL_ID=

# OpenRouter (openrouter.ai → Keys)
OPENROUTER_API_KEY=
# Модель фильтра (по умолчанию anthropic/claude-opus-4.8; для экономии — anthropic/claude-haiku-4.5)
LLM_MODEL=

# Период опроса источников, минуты (по умолчанию 10)
POLL_INTERVAL_MIN=

# Максимум негатива в фиде, % (по умолчанию 20; критичные предупреждения проходят всегда)
NEGATIVE_QUOTA_PCT=

# 1 = автопубликация без модерации (в личку придёт уведомление с кнопкой «убрать из канала»)
AUTO_PUBLISH=

# Час, после которого генерируется ежедневная рубрика (по умолчанию 10)
RUBRIC_HOUR=
