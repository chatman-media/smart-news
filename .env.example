# MTProto (my.telegram.org → API development tools)
TG_API_ID=
TG_API_HASH=

# Бот-модератор/публикатор (@BotFather)
BOT_TOKEN=

# Твой Telegram user id (личка, куда бот шлёт черновики) — узнать: @userinfobot
ADMIN_CHAT_ID=

# Канал для публикации: @username или -100xxxxxxxxxx (бот должен быть админом)
CHANNEL_ID=

# Anthropic
ANTHROPIC_API_KEY=
# Модель фильтра (по умолчанию claude-opus-4-8; для экономии можно claude-haiku-4-5)
CLAUDE_MODEL=

# Период опроса источников, минуты (по умолчанию 10)
POLL_INTERVAL_MIN=
